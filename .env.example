# OASIS Agentic Pipeline - Environment Configuration Template
# Copy this file to .env and fill in your values

# ============================================================================
# API Configuration
# ============================================================================

# API Server Settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# API Security (Production Only)
# API_KEY=your-secret-api-key-here
# JWT_SECRET=your-jwt-secret-here
# ALLOWED_ORIGINS=https://yourdomain.com

# ============================================================================
# Model Configuration
# ============================================================================

# Device Selection (auto, cpu, cuda, cuda:0, ...). 'auto' picks cuda if present.
DEVICE=auto

# Model Paths (optional - defaults to project structure)
# VISION_MODEL_PATH=src/pipeline/onnx_inference/best_vision_agent.pth
# ONNX_MODEL_PATH=src/pipeline/onnx_inference/multimodal_fusion_int8.onnx

# ============================================================================
# Hardware Acceleration — Windows ARM64 / Snapdragon NPU
# ============================================================================
# Preferred ONNX Runtime execution-provider chain (comma-separated). The runtime
# reconciles this against actually-available providers and falls back gracefully.
# Snapdragon NPU first, then DirectML GPU, then CPU.
ONNX_PROVIDERS=QNNExecutionProvider,DmlExecutionProvider,CPUExecutionProvider
# Qualcomm QNN backend library for the Hexagon NPU (requires onnxruntime-qnn).
QNN_BACKEND_PATH=QnnHtp.dll
QNN_HTP_PERFORMANCE_MODE=high_performance

# ============================================================================
# Hybrid Edge-Cloud LLM (Ollama — no paid API tokens)
# ============================================================================
ENABLE_LLM=true
# Edge tier: local Ollama daemon on the Snapdragon device.
OLLAMA_EDGE_URL=http://localhost:11434
OLLAMA_EDGE_MODEL=llama3.2:3b
# Cloud tier (OPTIONAL): a self-hosted Ollama endpoint for harder cases.
# Leave blank to keep everything fully on-device. Still free / no API key.
OLLAMA_CLOUD_URL=
OLLAMA_CLOUD_MODEL=llama3.1:8b
LLM_TIMEOUT_SECONDS=60
LLM_TEMPERATURE=0.2
# Escalate edge->cloud when confidence < this floor or the ethicist flags a case.
CLOUD_ESCALATION_CONFIDENCE=65.0
PREFER_CLOUD=false

# ============================================================================
# OASIS-3 / OASIS-4 Data Access (NITRC IR)
# ============================================================================
NITRC_USERNAME=hakeemadeniji
XNAT_BASE_URL=https://central.xnat.org
# FreeSurfer derivatives feed the Regional Volumetry agent (aseg.stats).
FREESURFER_ROOT=data/oasis_freesurfer
OASIS_SCANS_ROOT=data/oasis_scans
# PUP (PET Unified Pipeline) outputs feed the ATN amyloid/tau axes (SUVR).
PUP_ROOT=data/oasis_pup
# ATN positivity thresholds (screening priors; site-validate before clinical use).
AMYLOID_POSITIVE_CENTILOID=20.0
TAU_POSITIVE_SUVR=1.27

# ============================================================================
# Data Configuration
# ============================================================================

# Data Directories
DATA_ROOT=data/oasis_raw
PROCESSED_DATA_PATH=data/processed_tensors
VECTOR_STORE_PATH=data/vector_store

# Database
HITL_DB_PATH=data/active_learning.db

# ============================================================================
# Agent Configuration
# ============================================================================

# Confidence Thresholds
CONFIDENCE_FLOOR=65.0
ETHICIST_STRICT_MODE=false

# RAG Settings
RAG_TOP_K=3
RAG_SIMILARITY_THRESHOLD=0.7

# Temporal Analysis
TEMPORAL_LOOKBACK_YEARS=5

# ============================================================================
# Logging Configuration
# ============================================================================

# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log File Path
LOG_FILE=logs/oasis_pipeline.log

# ============================================================================
# Performance Configuration
# ============================================================================

# Batch Processing
MAX_BATCH_SIZE=32
INFERENCE_TIMEOUT=300

# Memory Management
TORCH_NUM_THREADS=4
OMP_NUM_THREADS=4

# ============================================================================
# Monitoring (Optional)
# ============================================================================

# Prometheus Metrics
# ENABLE_METRICS=true
# METRICS_PORT=9090

# Grafana Dashboard
# GRAFANA_URL=http://localhost:3000

# ============================================================================
# Development Settings (Remove in Production)
# ============================================================================

# Debug Mode
DEBUG=false

# Reload on Code Changes
RELOAD=false

# Mock Data Generation
USE_SYNTHETIC_DATA=false
