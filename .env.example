# OASIS Agentic Pipeline - Environment Configuration Template
# Copy this file to .env and fill in your values

# ============================================================================
# API Configuration
# ============================================================================

# API Server Settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# API Security (Production Only)
# API_KEY=your-secret-api-key-here
# JWT_SECRET=your-jwt-secret-here
# ALLOWED_ORIGINS=https://yourdomain.com

# ============================================================================
# Model Configuration
# ============================================================================

# Device Selection (cpu, cuda, cuda:0, cuda:1, etc.)
DEVICE=cpu

# Model Paths (optional - defaults to project structure)
# VISION_MODEL_PATH=src/pipeline/onnx_inference/best_vision_agent.pth
# ONNX_MODEL_PATH=src/pipeline/onnx_inference/multimodal_fusion_int8.onnx

# ============================================================================
# Data Configuration
# ============================================================================

# Data Directories
DATA_ROOT=data/oasis_raw
PROCESSED_DATA_PATH=data/processed_tensors
VECTOR_STORE_PATH=data/vector_store

# Database
HITL_DB_PATH=data/active_learning.db

# ============================================================================
# Agent Configuration
# ============================================================================

# Confidence Thresholds
CONFIDENCE_FLOOR=65.0
ETHICIST_STRICT_MODE=false

# RAG Settings
RAG_TOP_K=3
RAG_SIMILARITY_THRESHOLD=0.7

# Temporal Analysis
TEMPORAL_LOOKBACK_YEARS=5

# ============================================================================
# Logging Configuration
# ============================================================================

# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log File Path
LOG_FILE=logs/oasis_pipeline.log

# ============================================================================
# Performance Configuration
# ============================================================================

# Batch Processing
MAX_BATCH_SIZE=32
INFERENCE_TIMEOUT=300

# Memory Management
TORCH_NUM_THREADS=4
OMP_NUM_THREADS=4

# ============================================================================
# Monitoring (Optional)
# ============================================================================

# Prometheus Metrics
# ENABLE_METRICS=true
# METRICS_PORT=9090

# Grafana Dashboard
# GRAFANA_URL=http://localhost:3000

# ============================================================================
# Development Settings (Remove in Production)
# ============================================================================

# Debug Mode
DEBUG=false

# Reload on Code Changes
RELOAD=false

# Mock Data Generation
USE_SYNTHETIC_DATA=false
